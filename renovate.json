{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "baseBranches": [
    "develop"
  ],
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "bump",
  "minimumReleaseAge": "2 days",
  "packageRules": [
    {
      "description": "Tidy Go modules after updates",
      "matchManagers": [
        "gomod"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "description": "Use CI commit type for GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitType": "ci"
    }
  ]
}
